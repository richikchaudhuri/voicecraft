# --- Default provider (FREE) ---
# Get a free key at https://aistudio.google.com/apikey
# A standard key starts with "AIzaSy". If yours starts with "AQ." it may be a short-lived
# token that expires — generate a standard API key instead.
GEMINI_API_KEY=

# --- Optional premium provider (BILLED) ---
# https://console.anthropic.com  (a Claude.ai subscription does NOT include API usage)
ANTHROPIC_API_KEY=

# --- Fast free provider (RECOMMENDED) ---
# Groq is free AND very fast. Get a free key (no card) at https://console.groq.com/keys
# When set, codegen uses Groq; vision still uses Gemini. Pick a current model from
# https://console.groq.com/docs/models if the default is ever retired.
# Default = gpt-oss-120b (a reasoning model => best free design quality, but the tightest free
# rate limit). On a 429 it auto-falls back through GROQ_FALLBACKS in order.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FALLBACKS=qwen/qwen3-32b,llama-3.3-70b-versatile

# "gemini" or "claude" (premium). Routing prefers Groq for codegen when GROQ_API_KEY is set.
DEFAULT_PROVIDER=gemini

# Free default model. flash-lite has the most generous free-tier quota.
# On a 429 (per-model daily quota) the backend auto-falls back through GEMINI_FALLBACKS.
# Note: gemini-2.5-flash free tier is only ~20 requests/day; flash-lite is higher.
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_PRO=gemini-2.5-pro
